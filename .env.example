# PostgreSQL connection string
# Local example (Docker): postgresql://postgres:postgres@localhost:5432/global_dating?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/global_dating?schema=public"

# NextAuth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret-at-least-32-chars"

# Required in production behind a proxy
# AUTH_URL="https://your-domain.com"
# NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Crypto wallet addresses (defaults used if unset)
# CRYPTO_BTC_ADDRESS="bc1q..."
# CRYPTO_ETH_ADDRESS="0x..."
# CRYPTO_USDT_ADDRESS="T..."
# CRYPTO_USDC_ADDRESS="0x..."

# Set to "false" to require manual admin verification before activating crypto payments
# CRYPTO_AUTO_ACTIVATE="true"
